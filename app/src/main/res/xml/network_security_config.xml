<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Spyglass Connect uses cleartext WebSocket (ws://) on local WiFi.
         All messages are encrypted at the app level with AES-256-GCM,
         so transport-level TLS is not required for LAN communication. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
