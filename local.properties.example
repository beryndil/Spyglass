# Copy this file to local.properties and set your Android SDK path.
# local.properties is gitignored — never commit it.

sdk.dir=/home/YOUR_USERNAME/Android/Sdk

# For Android Studio on Linux the path is typically:
#   sdk.dir=/home/username/Android/Sdk
# On macOS:
#   sdk.dir=/Users/username/Library/Android/sdk
# On Windows:
#   sdk.dir=C\:\\Users\\username\\AppData\\Local\\Android\\Sdk

# Release signing (generate a keystore with keytool, then fill in these values):
# RELEASE_STORE_FILE=path/to/your-release-key.jks
# RELEASE_STORE_PASSWORD=your_store_password
# RELEASE_KEY_ALIAS=your_key_alias
# RELEASE_KEY_PASSWORD=your_key_password

# AdMob (defaults to test IDs if omitted — set these for production builds):
# ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
# ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
