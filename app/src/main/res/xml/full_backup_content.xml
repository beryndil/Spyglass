<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup rules (Android 11 and below).
    Only include user-created data — game content is re-seeded on launch.
-->
<full-backup-content>
    <include domain="database" path="spyglass_user.db" />
    <include domain="file" path="datastore/" />
    <include domain="file" path="connect/" />
    <include domain="sharedpref" path="." />
</full-backup-content>
