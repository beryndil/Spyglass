<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup rules (Android 12+).
    Preserves user data through uninstall/reinstall via Google Drive backup.
    Only user-created data is included — game content DB is re-seeded on launch.
-->
<cloud-backup-rules>
    <!-- User database: notes, waypoints, favorites, shopping lists, etc. -->
    <include domain="database" path="spyglass_user.db" />

    <!-- User preferences (DataStore): settings, pairing info, consent flags -->
    <include domain="file" path="datastore/" />

    <!-- Connect offline cache: player data, structures, map, skins, waypoints -->
    <include domain="file" path="connect/" />

    <!-- SharedPreferences: sync manifest, review tracking -->
    <include domain="sharedpref" path="." />
</cloud-backup-rules>
