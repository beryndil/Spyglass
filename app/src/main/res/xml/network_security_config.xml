<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext required for Spyglass Connect WebSocket (ws://) on local WiFi.
         Android domain-config cannot match IP addresses, so base-config must allow it.
         All HTTPS APIs (GitHub, Firebase, AdMob) enforce TLS regardless of this setting.
         Connect validates the target is a private IP before connecting. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
